{
  "env": {
    "node": true,
    "es2022": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "no-unused-vars": "error"
  },
  "ignorePatterns": ["node_modules/"],
  "overrides": [
    {
      "files": ["cypress/**/*.js"],
      "env": {
        "mocha": true
      },
      "globals": {
        "cy": "readonly",
        "Cypress": "readonly",
        "expect": "readonly"
      }
    }
  ]
}
