{
  "name": "lab-dependency-auditing-starter",
  "version": "1.0.0",
  "description": "Starter lab for npm audit + Snyk pipeline",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "npm audit --audit-level=high",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "start-server-and-test start http://localhost:3000 cy:run",
    "snyk:test": "snyk test"
  },
  "dependencies": {
    "express": "^4.21.2",
    "express-graphql": "^0.12.0",
    "graphql": "^15.10.1",
    "mongoose": "^8.18.0"
  },
  "devDependencies": {
    "cypress": "^14.5.4",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "snyk": "^1.1294.0",
    "start-server-and-test": "^2.0.8"
  }
}
