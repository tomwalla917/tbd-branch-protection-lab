{
  "name": "lab-linting-formatting-starter",
  "version": "1.0.0",
  "description": "Starter lab for ESLint and Prettier CI integration",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "start-server-and-test start http://localhost:3000 cy:run"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "cypress": "^14.5.4",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "start-server-and-test": "^2.0.8"
  }
}
